# ══════════════════════════════════════════════════════════════
#  Configuration RAG-DataAfriqueHub
#  Copiez ce fichier en .env et remplissez les valeurs requises.
# ══════════════════════════════════════════════════════════════

# Mode actif du pipeline : free | hybrid | premium
RAG_CONFIG=hybrid

# ── Mode FREE (free.yaml) ─────────────────────────────────────
# Requiert : HF_TOKEN
# Provider LLM : HuggingFace (Zephyr 7B)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Mode HYBRID (hybrid.yaml) ────────────────────────────────
# Requiert : GOOGLE_API_KEY + COHERE_API_KEY
# Provider LLM  : Gemini 2.0 Flash  → https://ai.google.dev
# Provider Rank : Cohere             → https://cohere.com
GOOGLE_API_KEY=
COHERE_API_KEY=

# ── Mode PREMIUM (premium.yaml) ──────────────────────────────
# Requiert : OPENAI_API_KEY + COHERE_API_KEY + PINECONE_API_KEY
# Provider LLM      : GPT-4 (OpenAI)
# Provider Embedding: text-embedding-3-large (OpenAI)
# Provider VectorDB : Pinecone (managed)
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws

# ── Authentification API (optionnel) ─────────────────────────
# Si défini, toutes les routes requièrent le header : X-API-Key
# Laisser vide pour désactiver l'auth (mode local/dev)
API_KEY=

# ── Frontend ─────────────────────────────────────────────────
# URL que le NAVIGATEUR utilise pour atteindre le backend.
# En local Docker : http://localhost:8000
# En production   : https://api.votre-domaine.com
VITE_API_URL=http://localhost:8000
